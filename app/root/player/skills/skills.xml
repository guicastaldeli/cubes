<?xml version="1.0" encoding="UTF-8"?>
<skills>
    {#grid(5,2)}
    {#foreach skillsdata as skill}
        <div 
            id="skill_{skill.Id}" 
            x="{col * 11 + 2}%" y="{row * 22 + 50}%" 
            width="10%" height="20%" 
            background="0.15,0.15,0.25,0.9" 
            hoverable="true" 
            hoverBackground="0.25,0.25,0.45,0.9" 
            hoverScale="1.05" 
            border="2" 
            borderColor="0.3,0.3,0.5,1"
        >
            <label 
                id="skill_{skill.Id}_name" 
                x="0%" y="8%" text="{skill.Name}" 
                color="1,1,1,1" 
                scale="0.5"
            >
                {skill.Name}
            </label>
        </div>
    {#end}
</skills>