{{@theme#test1}}
	id = -1,
	name = "TEST_1"
	movement = ~[
		gravity(8.0)
		speed(2.0)
		jump(2.0)
	],
	audio = "test.ogg"
	top = 1
	particles = ~[
		(live: true, playerMovSpeed: 5.0, playerStand: 1.0 :: emit(
			position:
			color: 0.5, 0.5, 0.5
			size: 0.5,
			speed: 1.0,
			lifetime: 20,
			velNum: 1.0,
			targetY: 1.0,
			enableMotion: true,
			spawnRadius: 1.0
		))
	],
	texture = "test1"
{{#end}}