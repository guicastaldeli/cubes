<?xml version="1.0" encoding="UTF-8"?>
<server_dialog>
    <button 
        id="backBtn" 
        x="2%" y="2%" 
        width="100" height="40"
        color="0.0, 0.0, 0.0" 
        background="1.0,1.0,1.0,1.0"
        action="back"
        hoverBackground="0.7, 0.7, 0.7, 1.0"
        textOffset="25%, 37%"
    >
        Back
    </button>

    <!-- Host Section -->
    <label x="20%" y="24%" scale="1.0" color="1.0,1.0,1.0,1.0">Host</label>
    <label x="20%" y="42%" scale="0.8" color="1.0,1.0,1.0,1.0">Max Players</label>
    <input id="maxPlayersInput" x="20%" y="46%" width="200" height="40" background="0.9,0.9,0.9,1.0" color="0.0,0.0,0.0,1.0" />
    <button 
        id="hostBtn" 
        x="20%" y="56%" 
        width="200" height="50"
        color="0.0,0.0,0.0" 
        background="1.0,1.0,1.0,1.0"
        action="host" 
        hoverBackground="0.7,0.7,0.7,1.0" 
        textOffset="25%,37%"
    >
        Host
    </button>

    <!-- Join Section -->
    <label x="60%" y="24%" scale="1.0" color="1.0,1.0,1.0,1.0">Join</label>
    <label x="60%" y="30%" scale="0.8" color="1.0,1.0,1.0,1.0">IP Address</label>
    <input id="ipInput" x="60%" y="34%" width="200" height="40" background="0.9,0.9,0.9,1.0" color="0.0,0.0,0.0,1.0" />
    <label x="60%" y="42%" scale="0.8" color="1.0,1.0,1.0,1.0">Port</label>
    <input id="joinPortInput" x="60%" y="46%" width="200" height="40" background="0.9,0.9,0.9,1.0" color="0.0,0.0,0.0,1.0" />
    <button 
        id="joinBtn" 
        x="60%" y="56%" 
        width="200" height="50"
        color="0.0,0.0,0.0" 
        background="1.0,1.0,1.0,1.0"
        action="join" 
        hoverBackground="0.7,0.7,0.7,1.0" 
        textOffset="25%,37%"
    >
        Join
    </button>
</server_dialog>