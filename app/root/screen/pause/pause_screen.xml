<?xml version="1.0" encoding="UTF-8"?>
<pause_screen>
    <button 
        id="resumeBtn" 
        x="20%" y="20%" 
        scale="1.0" 
        width="150"
        height="100"
        color="0.0, 0.0, 0.0" 
        background="1.0,1.0,1.0,1.0"
        action="resume"
        hoverTextColor="0.2, 0.2, 0.2, 1.0"
        hoverBackground="0.7, 0.7, 0.7, 1.0"
        textOffset="35%, 37%"
    >
        Resume
    </button>
    <button 
        id="backBtn" 
        x="20%" y="40%" 
        scale="1.0" 
        width="150"
        height="100"
        color="0.0, 0.0, 0.0" 
        background="1.0,1.0,1.0,1.0"
        action="back"
        hoverTextColor="0.2, 0.2, 0.2, 1.0"
        hoverBackground="0.7, 0.7, 0.7, 1.0"
        textOffset="35%, 37%"
    >
        Back to Menu
    </button>
</pause_screen>