<?xml version="1.0" encoding="UTF-8"?>
<themes>
    {#grid(5,2)}
    {#foreach platformthemes as theme}
        <div 
            id="theme_{theme.Id}" 
            x="{col * 11 + 2}%" y="{row * 22 + 2}%" 
            width="10%" height="20%" 
            background="0.15,0.15,0.25,0.9" 
            hoverable="true" 
            hoverBackground="0.25,0.25,0.45,0.9" 
            hoverScale="1.05"
            action="action_themes-{theme.Id}"
        >
            <label 
                id="theme_{theme.Id}_name" 
                x="0%" y="8%" text="{theme.Name}" 
                color="1,1,1,1" 
                scale="0.5"
            >
                {theme.Name}
            </label>
        </div>
    {#end}
</themes>